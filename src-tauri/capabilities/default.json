{
  "$schema": "../node_modules/@tauri-apps/cli/schema/capabilities.schema.json",
  "identifier": "default",
  "description": "Default capability set for Redline",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "process:allow-restart",
    "log:default"
  ]
}
