FROM rust:1.89-slim

# Tauri 2 system deps required even for cargo test --lib (tauri-build links against webkit/GTK).
# libayatana-appindicator3-dev omitted (Ubuntu-only; tray-icon feature not enabled).
RUN apt-get update -qq && apt-get install -y -qq \
  pkg-config \
  libssl-dev \
  libwebkit2gtk-4.1-dev \
  build-essential \
  wget \
  file \
  libxdo-dev \
  librsvg2-dev \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
# --chown=root:root normalises file ownership so the Docker layer cache is shared
# between builds on different machines (Mac dev vs Linux CI runner).
COPY --chown=root:root Cargo.toml Cargo.lock ./
COPY --chown=root:root src-tauri src-tauri
# pdf-diff is a workspace crate and a direct dependency of redline.
# Without this COPY the src-tauri compilation fails immediately
# because cargo cannot resolve the path dep ../crates/pdf-diff.
COPY --chown=root:root crates crates

ENV CARGO_TARGET_DIR=/target

# Run both workspace crates.
# PDFIUM_DYNAMIC_LIB_PATH is deliberately unset: PDFium-dependent tests in
# src-tauri skip gracefully via early-return when the env var is absent
# (matching the render::tests::corpus() helper pattern).
# pdf-diff tests are all pure-Rust (pixel math + serde) and run unconditionally;
# the single engine_new test handles Ok/Err without panic.
RUN cargo test --lib -p redline && cargo test --lib -p pdf-diff
